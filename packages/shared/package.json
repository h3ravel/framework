{
  "name": "@h3ravel/shared",
  "version": "2.2.0",
  "description": "Shared Utilities.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "tsconfig.base.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./*": "./*"
    }
  },
  "homepage": "https://h3ravel.toneflix.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h3ravel/framework.git",
    "directory": "packages/shared"
  },
  "keywords": [
    "h3ravel",
    "modern",
    "web",
    "H3",
    "framework",
    "nodejs",
    "typescript",
    "laravel"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --watch --config-loader unrun",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "jest --passWithNoTests",
    "release:patch": "pnpm build && pnpm version patch && git add . && git commit -m \"version: bump shared package and publish\" && pnpm publish --tag latest",
    "version-patch": "pnpm version patch"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.9.0",
    "chalk": "^5.6.0",
    "edge.js": "catalog:",
    "escalade": "catalog:",
    "h3": "catalog:prod",
    "inquirer-autocomplete-standalone": "^0.8.1",
    "jiti": "^2.7.0",
    "ora": "^9.1.0",
    "preferred-pm": "catalog:"
  },
  "devDependencies": {
    "@h3ravel/contracts": "workspace:^2.2.0",
    "fetchdts": "^0.1.6",
    "pnpm": "^10.14.0"
  }
}
