{
  "name": "@h3ravel/filesystem",
  "version": "0.4.15-alpha.10",
  "description": "Filesystem manager for H3ravel, providing shared file storage and filesystem utitlities for the framework.",
  "h3ravel": {
    "providers": [
      "FilesystemProvider"
    ]
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./commands": "./dist/commands.js",
    "./facades": "./dist/facades.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./*": "./*"
    }
  },
  "homepage": "https://h3ravel.toneflix.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h3ravel/framework.git",
    "directory": "packages/filesystem"
  },
  "keywords": [
    "h3ravel",
    "modern",
    "web",
    "H3",
    "framework",
    "nodejs",
    "typescript",
    "laravel",
    "filesystem",
    "storage",
    "utilities",
    "interface",
    "runtime",
    "application",
    "flydrive"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "vitest",
    "version-patch": "pnpm version patch"
  },
  "dependencies": {
    "@h3ravel/musket": "catalog:prod",
    "@h3ravel/shared": "workspace:^0.29.0-alpha.10",
    "@h3ravel/support": "workspace:^0.17.0-alpha.10",
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1011.0",
    "flydrive": "catalog:",
    "ssh2-sftp-client": "^12.1.0"
  },
  "peerDependencies": {
    "@h3ravel/core": "workspace:^1.22.0-alpha.10"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/ssh2-sftp-client": "^9.0.6"
  }
}